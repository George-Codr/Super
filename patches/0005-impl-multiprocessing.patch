+/* Construct a safe full path for shm objects in Termux */
+static int construct_shm_path(const char *name, char *buf, size_t bufsize) {
+    /* Skip leading slashes */
+    while (*name == '/') ++name;
+
+    if (*name == '\0') {
+        errno = EINVAL;
+        return -1;
+    }
+
+    int n = snprintf(buf, bufsize, "@TERMUX_PREFIX@/tmp/%s", name);
+    if (n < 0 || (size_t)n >= bufsize) {
+        errno = ENAMETOOLONG;
+        return -1;
+    }
+
+    return 0;
+}
+
+/* Ensure temp directory exists */
+static void ensure_tmp_dir(void) {
+    static int checked = 0;
+    if (!checked) {
+        char tmpdir[PATH_MAX];
+        snprintf(tmpdir, sizeof(tmpdir), "@TERMUX_PREFIX@/tmp");
+        mkdir(tmpdir, 0700);  /* ignore errors if it already exists */
+        checked = 1;
+    }
+}
+
+static int shm_unlink(const char *name) {
+    char fname[PATH_MAX];
+    if (construct_shm_path(name, fname, sizeof(fname)) != 0)
+        return -1;
+
+    return unlink(fname);
+}
+
+static int shm_open(const char *name, int oflag, mode_t mode) {
+    char fname[PATH_MAX];
+    if (construct_shm_path(name, fname, sizeof(fname)) != 0)
+        return -1;
+
+    ensure_tmp_dir();
+
+    int fd = open(fname, oflag, mode);
+    if (fd != -1) {
+        int fdflags = fcntl(fd, F_GETFD);
+        if (fdflags != -1) {
+            if (fcntl(fd, F_SETFD, fdflags | FD_CLOEXEC) == -1) {
+                int save_errno = errno;
+                close(fd);
+                fd = -1;
+                errno = save_errno;
+            }
+        }
+    }
+
+    return fd;
+}
